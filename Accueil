<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Ghostify — Dropshipping IA</title>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --bg:#FFFFFF;
  --surface:#FFFFFF;
  --ink:#0F0F0E;
  --muted:#9B9B95;
  --line:#E8E8E6;
  --green:#1C6843;
  --green-soft:#EBF5EF;
  --green-mid:#2E8B57;
  --serif:'Instrument Serif',Georgia,serif;
  --sans:'Inter',system-ui,sans-serif;
}

html,body{
  background:#FFFFFF;
  color:var(--ink);
  font-family:var(--sans);
  -webkit-font-smoothing:antialiased;
  min-height:100vh;
}

/* ── AD TOP ── */
.ad-top{
  width:100%;
  background:#FFFFFF;
  border-bottom:1px solid var(--line);
  min-height:68px;
  display:flex;align-items:center;justify-content:center;
  position:relative;
}
.ad-lbl{
  position:absolute;top:6px;left:14px;
  font-size:9px;letter-spacing:.1em;text-transform:uppercase;
  color:var(--muted);opacity:.5;
}
.ad-ph{
  width:728px;max-width:calc(100% - 28px);
  height:52px;
  background:#F0F0EE;
  border-radius:6px;
  border:1px dashed #D8D8D5;
  display:flex;align-items:center;justify-content:center;
  font-size:10px;color:var(--muted);letter-spacing:.06em;
}

/* ── NAV ── */
nav{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:22px 48px;
  max-width:1080px;
  margin:0 auto;width:100%;
  background:#FFFFFF;
}
.logo{
  display:flex;align-items:center;gap:9px;
  cursor:pointer;user-select:none;text-decoration:none;
}
.logo-mark{
  width:30px;height:30px;
  background:var(--green);
  border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.logo-name{
  font-family:var(--serif);
  font-size:19px;font-style:italic;
  color:var(--ink);letter-spacing:-.02em;
}
.nav-right{
  display:flex;align-items:center;gap:16px;
}
.nav-badge{
  font-size:11.5px;font-weight:500;
  color:var(--green);
  letter-spacing:.02em;
  background:var(--green-soft);
  border-radius:20px;
  padding:5px 13px;
  border:1px solid rgba(28,104,67,.12);
}

/* ── HERO ── */
.hero{
  display:flex;
  flex-direction:column;
  align-items:center;
  text-align:center;
  padding:88px 24px 80px;
  max-width:660px;
  margin:0 auto;width:100%;
  background:#FFFFFF;
}

.kicker{
  display:inline-flex;align-items:center;gap:7px;
  font-size:11.5px;font-weight:500;
  letter-spacing:.1em;text-transform:uppercase;
  color:var(--green);
  margin-bottom:32px;
}
.kicker-dot{
  width:5px;height:5px;
  background:var(--green);
  border-radius:50%;
  animation:pulse 2s ease-in-out infinite;
}

h1{
  font-family:var(--serif);
  font-size:clamp(46px,6.5vw,80px);
  font-weight:400;
  line-height:1.05;
  letter-spacing:-.035em;
  color:var(--ink);
  margin-bottom:24px;
}
h1 em{
  font-style:italic;
  color:var(--green);
}

.hero-sub{
  font-size:15px;line-height:1.75;
  color:var(--muted);font-weight:300;
  max-width:380px;
  margin-bottom:56px;
}

/* ── INPUT ── */
.input-wrap{
  width:100%;max-width:540px;
  display:flex;flex-direction:column;
  align-items:center;gap:14px;
}
.input-box{
  width:100%;
  display:flex;align-items:center;
  background:#FFFFFF;
  border:1.5px solid var(--line);
  border-radius:14px;
  padding:6px 6px 6px 18px;
  box-shadow:0 2px 8px rgba(0,0,0,.05),0 8px 32px rgba(0,0,0,.04);
  transition:border-color .2s,box-shadow .2s;
}
.input-box:focus-within{
  border-color:var(--green);
  box-shadow:0 2px 8px rgba(0,0,0,.04),0 8px 32px rgba(28,104,67,.1);
}
.url-inp{
  flex:1;border:none;outline:none;
  background:transparent;
  font-family:var(--sans);font-size:14px;
  color:var(--ink);min-width:0;
}
.url-inp::placeholder{color:var(--muted)}
.btn-go{
  background:var(--green);
  color:#fff;border:none;
  border-radius:10px;
  padding:11px 22px;
  font-family:var(--sans);font-size:13px;font-weight:500;
  cursor:pointer;
  white-space:nowrap;
  display:flex;align-items:center;gap:6px;
  transition:opacity .15s,transform .12s,background .15s;
  flex-shrink:0;
  letter-spacing:.01em;
}
.btn-go:hover{background:var(--green-mid);transform:translateY(-1px)}
.btn-go:active{transform:scale(.97)}
.btn-go:disabled{opacity:.4;cursor:not-allowed;transform:none}
.spin{width:13px;height:13px;border:1.5px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .65s linear infinite}

.trust-line{
  font-size:11.5px;color:var(--muted);
  display:flex;align-items:center;gap:6px;
}
.trust-dot{
  width:5px;height:5px;
  background:var(--green);border-radius:50%;
  display:inline-block;
}

/* ── PROGRESS ── */
.prog{width:100%;max-width:540px;display:none}
.prog.on{display:block}
.prog-track{height:2px;background:var(--line);border-radius:1px;overflow:hidden}
.prog-bar{height:100%;background:var(--green);width:0%;transition:width .45s cubic-bezier(.22,1,.36,1)}
.prog-txt{font-size:12px;color:var(--muted);margin-top:8px;font-style:italic}

/* ── FEATURES ── */
.features{
  display:flex;align-items:center;
  justify-content:center;
  gap:0;
  margin-top:64px;
  width:100%;max-width:480px;
}
.feat{
  flex:1;
  display:flex;flex-direction:column;
  align-items:center;
  gap:8px;
  padding:0 16px;
  position:relative;
}
.feat:not(:last-child)::after{
  content:'';
  position:absolute;right:0;top:50%;transform:translateY(-50%);
  width:1px;height:32px;
  background:var(--line);
}
.feat-icon{
  width:36px;height:36px;
  background:var(--green-soft);
  border-radius:10px;
  display:flex;align-items:center;justify-content:center;
}
.feat-label{
  font-size:12px;font-weight:500;
  color:var(--ink);letter-spacing:.01em;
}
.feat-sub{
  font-size:11px;color:var(--muted);
  text-align:center;line-height:1.4;
}

/* ── COMPATIBLE STRIP ── */
.compat{
  display:flex;align-items:center;gap:14px;
  margin-top:52px;
  width:100%;max-width:480px;
}
.compat-label{
  font-size:10.5px;letter-spacing:.1em;
  text-transform:uppercase;color:var(--muted);
  opacity:.55;white-space:nowrap;flex-shrink:0;
}
.compat-line{flex:1;height:1px;background:var(--line)}
.compat-names{display:flex;gap:16px;flex-shrink:0}
.compat-name{
  font-size:11.5px;font-weight:500;
  color:var(--muted);opacity:.65;
  letter-spacing:.02em;
}

/* ── MODAL ── */
.overlay{
  position:fixed;inset:0;
  background:rgba(15,15,14,.45);
  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);
  z-index:900;
  display:none;align-items:center;justify-content:center;
  padding:20px;
  animation:fi .22s ease;
}
.overlay.open{display:flex}
.modal{
  background:#FFFFFF;
  border:1px solid var(--line);
  border-radius:22px;
  padding:44px 40px;
  max-width:400px;width:100%;
  box-shadow:0 32px 100px rgba(0,0,0,.12),0 2px 8px rgba(0,0,0,.04);
  animation:fu .3s cubic-bezier(.16,1,.3,1);
  position:relative;
}
.modal-x{
  position:absolute;top:16px;right:16px;
  background:none;border:none;
  width:30px;height:30px;border-radius:50%;
  cursor:pointer;font-size:16px;color:var(--muted);
  display:flex;align-items:center;justify-content:center;
  transition:background .14s;
}
.modal-x:hover{background:#F5F5F3}
.preview-pill{
  display:inline-flex;align-items:center;gap:7px;
  background:var(--green-soft);
  border:1px solid rgba(28,104,67,.12);
  border-radius:20px;
  padding:5px 13px;
  margin-bottom:24px;
}
.preview-pulse{
  width:6px;height:6px;background:var(--green);
  border-radius:50%;animation:pulse 1.6s ease-in-out infinite;
}
.preview-label{font-size:11.5px;font-weight:500;color:var(--green)}
.modal-title{
  font-family:var(--serif);font-size:28px;font-weight:400;
  letter-spacing:-.03em;color:var(--ink);
  margin-bottom:6px;line-height:1.15;
}
.modal-sub{
  font-size:13px;color:var(--muted);
  margin-bottom:28px;line-height:1.6;font-weight:300;
}
.tabs{
  display:flex;gap:0;
  background:#FFFFFF;
  border:1px solid var(--line);
  border-radius:10px;padding:3px;
  margin-bottom:22px;
}
.tab{
  flex:1;padding:7px 12px;
  border:none;background:transparent;
  font-family:var(--sans);font-size:13px;
  cursor:pointer;border-radius:8px;
  color:var(--muted);transition:all .14s;
}
.tab.on{
  background:#FFFFFF;color:var(--ink);
  font-weight:500;
  box-shadow:0 1px 4px rgba(0,0,0,.07);
  border:1px solid var(--line);
}
.field{
  width:100%;
  background:#FFFFFF;
  border:1.5px solid var(--line);
  color:var(--ink);
  padding:11px 14px;border-radius:10px;
  font-size:13.5px;outline:none;
  font-family:var(--sans);font-weight:400;
  transition:border-color .18s,box-shadow .18s;
  margin-bottom:9px;display:block;
}
.field:focus{
  border-color:var(--green);
  box-shadow:0 0 0 3px rgba(28,104,67,.08);
  background:#FFFFFF;
}
.field::placeholder{color:var(--muted)}
.promo-row{display:flex;gap:6px;margin-bottom:9px}
.promo-row .field{margin-bottom:0;flex:1}
.btn-promo{
  background:#FFFFFF;border:1.5px solid var(--line);
  border-radius:9px;padding:0 13px;
  font-family:var(--sans);font-size:12.5px;
  cursor:pointer;color:var(--ink);white-space:nowrap;
  transition:background .14s;font-weight:400;
}
.btn-promo:hover{background:#F5F5F3}
.promo-ok{color:var(--green);font-size:12px;margin-bottom:8px;font-weight:500;display:none}
.promo-err{color:#c0392b;font-size:12px;margin-bottom:8px;display:none}
.err{background:#FEF2F2;color:#b91c1c;border-radius:8px;padding:9px 13px;font-size:12.5px;margin-bottom:12px;display:none}
.btn-main{
  width:100%;background:var(--green);color:#fff;
  border:none;border-radius:10px;
  padding:13px;font-family:var(--sans);
  font-size:13.5px;font-weight:500;
  cursor:pointer;transition:opacity .15s,transform .12s,background .15s;
  margin-top:4px;letter-spacing:.01em;
}
.btn-main:hover{background:var(--green-mid);transform:translateY(-1px)}
.btn-main:active{transform:scale(.97)}
.modal-foot{
  text-align:center;font-size:11px;
  color:var(--muted);margin-top:14px;
  line-height:1.6;font-weight:300;
}
.su-only{display:block}

/* ── FOOTER ── */
footer{
  text-align:center;
  padding:20px 24px 90px;
  font-size:11px;color:var(--muted);
  opacity:.5;letter-spacing:.04em;
  background:#FFFFFF;
}

/* ── AD STICKY ── */
.ad-sticky{
  position:fixed;bottom:0;left:0;right:0;
  z-index:700;
  background:#FFFFFF;
  border-top:1px solid var(--line);
  padding:6px 12px 8px;
  display:flex;align-items:center;justify-content:center;flex-direction:column;
}
.ad-sticky .ad-ph{height:50px;max-width:728px}

/* ── KEYFRAMES ── */
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes fi{from{opacity:0}to{opacity:1}}
@keyframes fu{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.85)}}

/* ── RESPONSIVE ── */
@media(max-width:600px){
  nav{padding:18px 20px}
  .hero{padding:64px 20px 60px}
  .input-box{flex-direction:column;padding:10px 14px;gap:10px;align-items:stretch}
  .btn-go{justify-content:center;border-radius:9px}
  .modal{padding:32px 22px}
  h1{font-size:clamp(38px,10vw,56px)}
  .features{flex-direction:column;gap:24px}
  .feat::after{display:none}
}
</style>
</head>
<body>

<!-- AD TOP -->
<div class="ad-top">
  <span class="ad-lbl">Sponsorisé</span>
  <div class="ad-ph">728 × 60</div>
</div>

<!-- NAV -->
<nav>
  <div class="logo" id="logo">
    <div class="logo-mark">
      <svg width="17" height="17" viewBox="0 0 32 32" fill="none">
        <path d="M16 4C10.477 4 6 8.477 6 14v12.5l3-3 3.5 3.5 3.5-3.5 3.5 3.5 3.5-3.5 3 3V14c0-5.523-4.477-10-10-10z" fill="white"/>
        <circle cx="12.5" cy="14" r="2" fill="rgba(28,104,67,0.6)"/>
        <circle cx="19.5" cy="14" r="2" fill="rgba(28,104,67,0.6)"/>
      </svg>
    </div>
    <span class="logo-name">Ghostify</span>
  </div>
  <div class="nav-right">
    <span class="nav-badge">Gratuit pour démarrer</span>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <p class="kicker">
    <span class="kicker-dot"></span>
    Dropshipping IA
  </p>

  <h1>Colle un lien.<br><em>Vends en 60s.</em></h1>

  <p class="hero-sub">
    Génère une boutique complète depuis n'importe quel produit — sans code, sans carte.
  </p>

  <div class="input-wrap">
    <div class="input-box">
      <input class="url-inp" id="urlInput" type="url"
        placeholder="Colle ton lien produit ici…"
        autocomplete="off"/>
      <button class="btn-go" id="btnGen">
        Générer <span style="opacity:.6">→</span>
      </button>
    </div>

    <div class="prog" id="prog">
      <div class="prog-track"><div class="prog-bar" id="progBar"></div></div>
      <p class="prog-txt" id="progTxt"></p>
    </div>

    <p class="trust-line">
      <span class="trust-dot"></span>
      100% gratuit · Aucune carte requise
    </p>
  </div>

  <!-- FEATURES -->
  <div class="features">
    <div class="feat">
      <div class="feat-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
        </svg>
      </div>
      <span class="feat-label">Branding</span>
      <span class="feat-sub">Ta marque, ton identité</span>
    </div>
    <div class="feat">
      <div class="feat-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
        </svg>
      </div>
      <span class="feat-label">Vidéo IA</span>
      <span class="feat-sub">Contenu généré auto</span>
    </div>
    <div class="feat">
      <div class="feat-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"/>
        </svg>
      </div>
      <span class="feat-label">Logo</span>
      <span class="feat-sub">Créé en quelques secondes</span>
    </div>
  </div>

  <!-- COMPAT -->
  <div class="compat">
    <span class="compat-label">Compatible</span>
    <div class="compat-line"></div>
    <div class="compat-names">
      <span class="compat-name">AliExpress</span>
      <span class="compat-name">CJ</span>
      <span class="compat-name">Temu</span>
    </div>
  </div>
</section>

<footer>Made in France &nbsp;·&nbsp; Ghostify © 2025</footer>

<!-- MODAL -->
<div class="overlay" id="modal">
  <div class="modal">
    <button class="modal-x" id="modalX">✕</button>
    <div class="preview-pill">
      <span class="preview-pulse"></span>
      <span class="preview-label" id="previewUrl">Site généré</span>
    </div>
    <h2 class="modal-title" id="mTitle">Crée ton compte</h2>
    <p class="modal-sub" id="mSub">Accède à ton site et commence à vendre — gratuitement.</p>
    <div class="tabs">
      <button class="tab on" id="tabS" onclick="switchTab('s')">Inscription</button>
      <button class="tab" id="tabL" onclick="switchTab('l')">Connexion</button>
    </div>
    <div class="err" id="authErr"></div>
    <input class="field su-only" id="authName" placeholder="Ton prénom"/>
    <input class="field" id="authEmail" type="email" placeholder="E-mail" autocomplete="email"/>
    <input class="field" id="authPass" type="password" placeholder="Mot de passe" autocomplete="current-password"/>
    <div class="promo-row su-only">
      <input class="field" id="promoInp" placeholder="Code promo (optionnel)"/>
      <button class="btn-promo" onclick="applyPromo()">Appliquer</button>
    </div>
    <p class="promo-ok" id="promoOk"></p>
    <p class="promo-err" id="promoErr">Code invalide.</p>
    <button class="btn-main" id="btnAuth">Accéder à mon site →</button>
    <p class="modal-foot" id="mFoot">Aucune carte requise · 100% gratuit pour démarrer</p>
  </div>
</div>

<!-- AD STICKY -->
<div class="ad-sticky">
  <span class="ad-lbl">Sponsorisé</span>
  <div class="ad-ph">728 × 50</div>
</div>

<script>
const PROMOS = {LEGHOST10:"1 mois PRO offert",GHOST2026:"1 mois PRO offert"};
const VALID  = ["aliexpress","cjdropshipping","temu","http"];
const STEPS  = [
  "Analyse du produit…",
  "Extraction des données…",
  "Génération du contenu…",
  "Optimisation SEO…",
  "Finalisation de la boutique…",
  "Site prêt.",
];

let tab = "s", genUrl = "", lc = 0, lt = null;
const $ = id => document.getElementById(id);

function validSrc(u){ return VALID.some(s=>u.toLowerCase().includes(s)); }

function startGen(){
  const url = $("urlInput").value.trim();
  if(!url || !validSrc(url)) return;
  const btn = $("btnGen");
  btn.disabled = true;
  btn.innerHTML = '<span class="spin"></span>';
  const prog = $("prog");
  prog.classList.add("on");
  let step = 0;
  const iv = setInterval(()=>{
    step++;
    const pct = Math.min(Math.round((step/STEPS.length)*100), 97);
    $("progBar").style.width = pct+"%";
    $("progTxt").textContent = STEPS[Math.min(step, STEPS.length-1)];
    if(step >= STEPS.length){
      clearInterval(iv);
      $("progBar").style.width = "100%";
      const slug = url.split("/").pop()?.slice(0,22)?.replace(/[^a-z0-9]/gi,"-")||"boutique";
      genUrl = "ghostify.fr/"+slug;
      setTimeout(openModal, 500);
    }
  }, 480);
}

$("btnGen").addEventListener("click", startGen);
$("urlInput").addEventListener("keydown", e=>{ if(e.key==="Enter") startGen(); });

function openModal(){
  $("previewUrl").textContent = genUrl;
  $("modal").classList.add("open");
}
$("modalX").addEventListener("click", ()=>$("modal").classList.remove("open"));
$("modal").addEventListener("click", e=>{ if(e.target===$("modal")) $("modal").classList.remove("open"); });

function switchTab(t){
  tab = t;
  $("tabS").classList.toggle("on", t==="s");
  $("tabL").classList.toggle("on", t==="l");
  document.querySelectorAll(".su-only").forEach(el=>el.style.display=t==="s"?"block":"none");
  $("mTitle").textContent  = t==="s" ? "Crée ton compte" : "Content de te revoir";
  $("mSub").textContent    = t==="s" ? "Accède à ton site et commence à vendre — gratuitement." : "Connecte-toi pour accéder à ton espace.";
  $("btnAuth").textContent = t==="s" ? "Accéder à mon site →" : "Me connecter →";
  $("mFoot").textContent   = t==="s" ? "Aucune carte requise · 100% gratuit pour démarrer" : "Pas encore de compte ? Inscris-toi gratuitement.";
  $("authErr").style.display = "none";
}

function applyPromo(){
  const code = $("promoInp").value.trim().toUpperCase();
  if(PROMOS[code]){ $("promoOk").textContent="✓ "+PROMOS[code]+" appliqué"; $("promoOk").style.display="block"; $("promoErr").style.display="none"; }
  else{ $("promoErr").style.display="block"; $("promoOk").style.display="none"; }
}

$("btnAuth").addEventListener("click",()=>{
  const err  = $("authErr");
